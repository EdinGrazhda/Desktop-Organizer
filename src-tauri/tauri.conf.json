{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "N'Rend",
  "version": "1.0.3",
  "identifier": "com.desknest.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "N'Rend",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": true,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
